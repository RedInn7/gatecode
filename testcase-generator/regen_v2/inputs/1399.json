{"pid":1399,"slug":"length-of-the-longest-alphabetical-continuous-substring","inferred_constraints":"1<=s.length<=10^5; s consists of lowercase letters","input_format":"line 1: s (string)","testcases":[{"input":"abacaba","desc":"Edge: example1 -> 2","output":"2"},{"input":"abcde","desc":"Edge: example2 -> 5","output":"5"},{"input":"a","desc":"Edge: single char -> 1","output":"1"},{"input":"z","desc":"Edge: single z -> 1","output":"1"},{"input":"abcdefghijklmnopqrstuvwxyz","desc":"Edge: full alphabet -> 26","output":"26"},{"input":"zyxwvutsrqponmlkjihgfedcba","desc":"Killer: reverse alphabet -> 1","output":"1"},{"input":"aabbccdd","desc":"Standard: pairs no continuity -> 2 (ab)","output":"2"},{"input":"xyzabc","desc":"Standard: wraps z->a no continuity -> 3","output":"3"},{"input":"mnopqrst","desc":"Standard: long mid-alpha run -> 8","output":"8"},{"input":"abcdzyxw","desc":"Standard: forward then reverse","output":"4"},{"input":"aaaaaaaaaa","desc":"Standard: all same -> 1","output":"1"},{"input":"abababababab","desc":"Standard: alternating -> 2","output":"2"},{"input":"bcdefghijklmnopqrstuvwxyza","desc":"Stress: full cycle shifted","output":"25"},{"input":"azbycxdwev","desc":"Standard: interleaved","output":"1"},{"input":"lmnopqrstuvwxyz","desc":"Stress: 15-char run -> 15","output":"15"},{"input":"abcdeabcde","desc":"Standard: repeated block","output":"5"},{"input":"nopqrstuv","desc":"Standard: 9-char mid run -> 9","output":"9"},{"input":"qrstuvwxyzabcd","desc":"Killer: long run then reset","output":"10"},{"input":"aaabbbccc","desc":"Standard: blocks","output":"2"},{"input":"hijklmnopqrstuvwxyzab","desc":"Stress: 18-char run from h","output":"19"}]}