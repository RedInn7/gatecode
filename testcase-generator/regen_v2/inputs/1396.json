{"pid":1396,"slug":"sentence-similarity-iii","inferred_constraints":"1<=sentence1,sentence2 length<=100; words separated by single space","input_format":"line 1: sentence1; line 2: sentence2","testcases":[{"input":"My name is Haley\nMy Haley","desc":"Edge: example1 -> true","output":"true"},{"input":"of\na good and of","desc":"Edge: example2 -> false","output":"true"},{"input":"Eating right now\nEating","desc":"Edge: example3 -> true","output":"true"},{"input":"a\na","desc":"Edge: identical single word","output":"true"},{"input":"a\nb","desc":"Edge: single different words -> false","output":"false"},{"input":"hello world\nhello world","desc":"Standard: identical -> true","output":"true"},{"input":"I am a good student\nI student","desc":"Standard: insert in middle","output":"true"},{"input":"The cat sat on the mat\nThe mat","desc":"Killer: remove large middle","output":"true"},{"input":"A B C D E\nA E","desc":"Standard: keep ends","output":"true"},{"input":"A B C\nB C","desc":"Standard: remove prefix","output":"true"},{"input":"A B C\nA B","desc":"Standard: remove suffix","output":"true"},{"input":"A B C\nA B C D","desc":"Standard: s2 is extension -> false","output":"true"},{"input":"A\nA B","desc":"Edge: one word vs two","output":"true"},{"input":"hello\nhello world","desc":"Edge: prefix only","output":"true"},{"input":"world hello\nhello","desc":"Standard: suffix only","output":"true"},{"input":"a b c d e f\na f","desc":"Stress: remove 4 middle","output":"true"},{"input":"x y z\ny z","desc":"Standard: remove first word","output":"true"},{"input":"x y z\nx y","desc":"Standard: remove last word","output":"true"},{"input":"one two three four\none four","desc":"Killer: remove two middle","output":"true"},{"input":"long sentence with many words here\nlong here","desc":"Stress: long remove","output":"true"}]}