{
  "pid": 1378,
  "slug": "split-bst",
  "inferred_constraints": "0<=node.val<=10^4; 0<=target<=10^7; BST is valid",
  "input_format": "line 1: root (BST as level-order JSON); line 2: target",
  "testcases": [
    {
      "input": "[4,2,6,1,3,5,7]\n2",
      "desc": "Edge: example -> [[2,1],[6,4,7,3,5]] or similar",
      "output": "[[2, 1], [4, 3, 6, null, null, 5, 7]]"
    },
    {
      "input": "[1]\n1",
      "desc": "Edge: single node target=root",
      "output": "[[1], null]"
    },
    {
      "input": "[5]\n3",
      "desc": "Edge: single node target<root",
      "output": "[null, [5]]"
    },
    {
      "input": "[5]\n7",
      "desc": "Edge: single node target>root",
      "output": "[[5], null]"
    },
    {
      "input": "[2,1,3]\n2",
      "desc": "Edge: 3 nodes split at root",
      "output": "[[2, 1], [3]]"
    },
    {
      "input": "[4,2,6,1,3,5,7]\n4",
      "desc": "Standard: split at root",
      "output": "[[4, 2, null, 1, 3], [6, 5, 7]]"
    },
    {
      "input": "[4,2,6,1,3,5,7]\n0",
      "desc": "Killer: target < all nodes",
      "output": "[null, [4, 2, 6, 1, 3, 5, 7]]"
    },
    {
      "input": "[4,2,6,1,3,5,7]\n10",
      "desc": "Killer: target > all nodes",
      "output": "[[4, 2, 6, 1, 3, 5, 7], null]"
    },
    {
      "input": "[8,4,12,2,6,10,14,1,3,5,7,9,11,13,15]\n7",
      "desc": "Stress: perfect BST split at 7",
      "output": "[[4, 2, 6, 1, 3, 5, 7], [8, null, 12, 10, 14, 9, 11, 13, 15]]"
    },
    {
      "input": "[10,5,15,3,7,13,18]\n6",
      "desc": "Standard: split between values",
      "output": "[[5, 3], [10, 7, 15, null, null, 13, 18]]"
    },
    {
      "input": "[6,3,8,1,4,7,9]\n5",
      "desc": "Standard: split in mid range",
      "output": "[[3, 1, 4], [6, null, 8, 7, 9]]"
    },
    {
      "input": "[100,50,150,25,75,125,175]\n60",
      "desc": "Stress: large values",
      "output": "[[50, 25], [100, 75, 150, null, null, 125, 175]]"
    },
    {
      "input": "[10,5,15]\n5",
      "desc": "Standard: 3 nodes split at left child",
      "output": "[[5], [10, null, 15]]"
    },
    {
      "input": "[10,5,15]\n15",
      "desc": "Standard: 3 nodes split at right child",
      "output": "[[10, 5, 15], null]"
    },
    {
      "input": "[1,null,2,null,null,null,3]\n1",
      "desc": "Killer: right-skewed BST",
      "output": "[[1], [2]]"
    },
    {
      "input": "[5,4,6,3,null,null,7,2]\n4",
      "desc": "Standard: complex left subtree",
      "output": "[[4, 3, null, 2], [5, null, 6, null, 7]]"
    },
    {
      "input": "[10,2,15,1,8,12,20,null,null,5,9]\n8",
      "desc": "Stress: split in dense left",
      "output": "[[2, 1, 8, null, null, 5], [10, 9, 15, null, null, 12, 20]]"
    },
    {
      "input": "[20,10,30,5,15,25,35]\n16",
      "desc": "Standard: between 15 and 20",
      "output": "[[10, 5, 15], [20, null, 30, 25, 35]]"
    },
    {
      "input": "[9,3,13,1,6,11,15,null,2,4,7,10,12,14]\n7",
      "desc": "Stress: large BST mid",
      "output": "[[3, 1, 6, null, 2, 4, 7], [9, null, 13, 11, 15, 10, 12, 14]]"
    },
    {
      "input": "[4,2,6,1,3,5,7]\n3",
      "desc": "Standard: split at 3",
      "output": "[[2, 1, 3], [4, null, 6, 5, 7]]"
    }
  ]
}