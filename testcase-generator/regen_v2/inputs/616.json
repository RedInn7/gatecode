{"pid":616,"slug":"perform-string-shifts","inferred_constraints":"1 <= s.length <= 100; s lowercase; 1 <= shift.length <= 100; shift[i][0] in {0,1}; 0 <= shift[i][1] <= 100","input_format":"line1: s (string); line2: shift (JSON 2D)","testcases":[{"input":"abc\n[[0,1],[1,2]]","desc":"Edge: example1","output":"\"cab\""},{"input":"abcdefg\n[[1,1],[1,1],[0,2],[1,3]]","desc":"Edge: example2","output":"\"efgabcd\""},{"input":"\"tzncok\"\n[[-832,935],[144,-358]]","desc":"Edge: monotone increasing sequence","output":"\"ktznco\""},{"input":"\"xzhjin\"\n[[-248,-674],[241,906]]","desc":"Edge: monotone decreasing sequence","output":"\"hjinxz\""},{"input":"a\n[[1,1]]","desc":"Edge: single char right shift","output":"\"a\""},{"input":"abc\n[[0,0]]","desc":"Edge: zero shift no change","output":"\"abc\""},{"input":"abc\n[[0,3]]","desc":"Edge: full rotation left","output":"\"abc\""},{"input":"abc\n[[1,3]]","desc":"Edge: full rotation right","output":"\"abc\""},{"input":"abcdef\n[[0,2]]","desc":"Standard: left 2","output":"\"cdefab\""},{"input":"abcdef\n[[1,2]]","desc":"Standard: right 2","output":"\"efabcd\""},{"input":"hello\n[[0,1],[1,1]]","desc":"Standard: cancel","output":"\"hello\""},{"input":"abcdef\n[[0,1],[0,1],[0,1]]","desc":"Standard: 3 left","output":"\"defabc\""},{"input":"abcdef\n[[1,1],[1,1],[1,1]]","desc":"Standard: 3 right","output":"\"defabc\""},{"input":"aaaaaa\n[[0,3],[1,2]]","desc":"Standard: all same chars","output":"\"aaaaaa\""},{"input":"abcdefghij\n[[0,5]]","desc":"Standard: half rotation","output":"\"fghijabcde\""},{"input":"abcdefghij\n[[0,3],[1,8],[0,2]]","desc":"Standard: net result","output":"\"hijabcdefg\""},{"input":"abcdefghijklmnopqrstuvwxyz\n[[0,13]]","desc":"Stress: half alphabet","output":"\"nopqrstuvwxyzabcdefghijklm\""},{"input":"abcdefghijklmnopqrstuvwxyz\n[[1,100],[0,100],[1,100],[0,100]]","desc":"Stress: cancel huge shifts","output":"\"abcdefghijklmnopqrstuvwxyz\""},{"input":"abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmno