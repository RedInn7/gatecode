{"pid":727,"slug":"minimum-cost-to-convert-string-ii","inferred_constraints":"1 <= source.length == target.length <= 1000, 1 <= cost <= 1e6, originals/changes lowercase","input_format":"line1: source; line2: target; line3: original (JSON array of strings); line4: changed (JSON array of strings); line5: cost (JSON array)","testcases":[{"input":"abcd\nacbe\n[\"a\",\"b\",\"c\",\"c\",\"e\",\"d\"]\n[\"b\",\"c\",\"b\",\"e\",\"b\",\"e\"]\n[2,5,5,1,2,20]","desc":"Edge: example1","output":"28"},{"input":"abcdefgh\nacdeeghh\n[\"bcd\",\"fgh\",\"thh\"]\n[\"cde\",\"thh\",\"ghh\"]\n[1,3,5]","desc":"Edge: example2","output":"9"},{"input":"abcdefgh\naddddddd\n[\"bcd\",\"defgh\"]\n[\"ddd\",\"ddddd\"]\n[100,1578]","desc":"Edge: example3 -1","output":"-1"},{"input":"a\na\n[\"a\"]\n[\"b\"]\n[1]","desc":"Edge: identical no cost","output":"0"},{"input":"a\nb\n[\"a\"]\n[\"b\"]\n[5]","desc":"Edge: simple replace","output":"5"},{"input":"a\nc\n[\"a\",\"b\"]\n[\"b\",\"c\"]\n[1,2]","desc":"Edge: 2-step","output":"3"},{"input":"abc\nabc\n[\"a\"]\n[\"b\"]\n[10]","desc":"Edge: no change needed","output":"0"},{"input":"abcd\nefgh\n[\"abcd\"]\n[\"efgh\"]\n[100]","desc":"Standard: single replacement","output":"100"},{"input":"abc\ndef\n[\"a\",\"b\",\"c\"]\n[\"d\",\"e\",\"f\"]\n[1,2,3]","desc":"Standard: char-by-char","output":"6"},{"input":"abcabc\nxyzxyz\n[\"abc\"]\n[\"xyz\"]\n[10]","desc":"Standard: 2 occurrences","output":"20"},{"input":"ab\nba\n[\"ab\"]\n[\"ba\"]\n[5]","desc":"Standard: swap pair","output":"5"},{"input":"abcd\nzzzz\n[\"a\"]\n[\"z\"]\n[1]","desc":"Standard: impossible if no rules","output":"-1"},{"input":"hello\nworld\n[\"h\",\"e\",\"l\",\"o\"]\n[\"w\",\"o\",\"r\",\"d\"]\n[1,1,1,1]","desc":"Standard: 4 chars uneven","output":"4"},{"input":"aa\nbb\n[\"a\"]\n[\"b\"]\n[3]","desc":"Standard: 2x same change","output":"6"},{"input":"abcdef\nabcxef\n[\"d\"]\n[\"x\"]\n[100]","desc":"Standard: single middle","output":"100"},{"input":"abc\ncba\n[\"abc\"]\n[\"cba\"]\n[7]","desc":"Standard: reverse single","output":"7"},{"input":"aaaaaaaaaa\nzzzzzzzzzz\n[\"a\"]\n[\"z\"]\n[1]","desc":"Standard: 10 same replace","output":"10"},{"input":"abcdefghij\njihgfedcba\n[\"abcde\"]\n[\"jihgf\"]\n[50]","desc":"Standard: half reverse","output":"-1"},{"input":"abcabcabc\nxyzxyzxyz\n[\"abc\"]\n[\"xyz\"]\n[2]","desc":"Standard: 3 occurrences","output":"6"},{"input":"abcd\nxyzw\n[\"ab\",\"cd\"]\n[\"xy\",\"zw\"]\n[3,4]","desc":"Special: disjoint pairs","output":"7"}]}